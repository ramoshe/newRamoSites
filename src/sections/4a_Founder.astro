---
import PhotoHang from '../components/PhotoHang.astro';

import Hello from '../assets/hiRamo.svg';
import Portrait from '../assets/portrait.jpg';

interface Props {
   data: { experience: string[], goal: string[] };
}

const { data } = Astro.props as Props;
---

<section id="founder" class="section">
   <div class="container stack flow">
      <div class="hello">
         <Hello />
      </div>
      <div class="grid">
         <div class="image">
            <PhotoHang src={Portrait.src} alt="Ramo's portrait" />
         </div>
         <div class="story flow">
            <!-- {data.experience.map(p => <p>{p}</p>)} -->
            <p>{data.experience[0]}</p>
            <p>{data.experience[1]}</p>
         </div>
         <div class="story flow">
            <p>{data.goal[0]} <span class="mark">{data.goal[1]}</span></p>
            <p>{data.goal[2]} <span class="mark">{data.goal[3]}</span></p>
         </div>
      </div>
   </div>
</section>

<style>
   .section {
      background-color: var(--page-0);
      container-type: inline-size;
   }
   .hello svg {
      padding-inline: var(--size-fluid-7);
      fill: var(--second);
   }
   .image {
      padding-inline: var(--size-3);
      max-inline-size: var(--size-14);
   }
   .story p {
      font-size: var(--font-size-1);
   }
   .mark {
      font-size: var(--font-size-3);
      color: var(--brand-t);
      font-weight: bold;
   }

   @container (max-width: 60rem) {
      .grid { --grid-columns: 1fr 1fr; }
      .hello svg { padding-inline: var(--size-fluid-5); }
      .image { grid-column: 1/-1; justify-self: center; }
   }

   @container (max-width: 40rem) {
      .grid { --grid-columns: 1fr; }
      .hello svg { padding-inline: var(--size-fluid-2); }
      .flow { max-inline-size: 45ch; }
      .image { max-inline-size: var(--size-13); }
   }
</style>