---
import Button from '../Button.astro';

import { Icon } from 'astro-icon/components';

import { LINKS } from '../../content/consts.ts';

type cta = {
   buttonText: string,
   description: string
}
interface Props {
   data: {
      survey: cta
      email: cta
   };
}

const { data } = Astro.props as Props;
---

<section id="cta" class="flex-col section-pad graph-paper">
   <div class="flex-row">
      <p>{data.survey.description}</p>
      <Icon name="tabler:arrow-big-right-line" class="icon" />
      <Button text={data.survey.buttonText} link={LINKS.survey} />
   </div>
   <div class="line"></div>
   <div class="flex-row">
      <Button text={data.email.buttonText} link='#cta' id="email-form-btn" />
      <Icon name="tabler:arrow-big-left-line" class="icon" />
      <p>{data.email.description}</p>
      <div class="email-form">
         <script async data-uid="4357918fec" src="https://theramoshe.kit.com/4357918fec/index.js"></script>
      </div>
   </div>
</section>

<style>
   #cta {
      text-align: center;
      gap: var(--size-9);
   }
   .line {
      height: var(--size-1);
      width: 100%;
      background-color: var(--text);
   }
   p {
      text-wrap: balance;
      font-size: 140%;
      color: var(--text-0);
   }
   .email-form {
      display: none;
   }
</style>
<script>
   const emailForm = document.querySelector('.email-form') as HTMLElement;
   const formBtn = document.querySelector('#email-form-btn') as HTMLElement;
   formBtn?.addEventListener('click', () => {
      const current = window.getComputedStyle(emailForm).display;
      emailForm.style.display = current === "none" ? "block" : "none";
   });
</script>