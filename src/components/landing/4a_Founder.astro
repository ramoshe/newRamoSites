---
import Hello from '../../assets/hiRamo.svg';
import Portrait from '../../assets/portrait.jpg';

import { Image } from 'astro:assets';

interface Props {
   data: { body: Array<string> };
}

const { data } = Astro.props as Props;
---

<section id="founder" class="section-pad">
   <div class="hello">
      <Hello />
   </div>
   <div class="grid-thirds">
      <div class="third first-third flow">
         {data.body.slice(0, 2).map(p => <p>{p}</p>)}
      </div>
      <div class="third middle-third flow">
         <Image src={Portrait} alt="Ramo's portrait" class="photo" />
      </div>
      <div class="third last-third flow">
         {data.body.slice(2).map(p => <p>{p}</p>)}
      </div>
   </div>
</section>

<style>
   #founder {
      background-color: var(--page-0);
   }
   .hello {
      display: flex;
      justify-content: center;
      align-items: center;
      padding-block-end: var(--size-7);
   }
   .hello svg {
      fill: var(--second-t);
   }
   .photo {
      inline-size: 100%;
      max-inline-size: 300px;
      block-size: 300px;
      object-fit: cover;
   }
   .last-third p:last-of-type {
      font-family: var(--font-fancy);
      font-size: 140%;
      color: var(--brand-t)
   }
</style>