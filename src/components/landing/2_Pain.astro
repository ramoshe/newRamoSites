---
type splitSection = {
   heading: string,
   subheading?: string,
   body: string
}
interface Props {
   data: {
      visual: splitSection,
      copy: splitSection
   };
}

const { data } = Astro.props as Props;
---
<section id="pain" class="section">
   <div class="container grid">
      <div class="copy | flow">
         <h2>{data.copy.heading}</h2>
         <h3>{data.copy.subheading}</h3>
         <p>{data.copy.body}</p>
      </div>
      <div class="visual | stack">
         <h3>{data.visual.heading}</h3>
         <div class="socialVisual placeholder">
            <!-- TODO add visual with social icons floating -->
         </div>
         <p>{data.visual.body}</p>
      </div>
   </div>
</section>

<style>
   .section {
      container-type: inline-size;
   }
   .visual {
      text-align: center;
   }
   .socialVisual {
      inline-size: 90%;
      margin: auto;
      aspect-ratio: 1;
   }

   @container (max-width: 40rem) {
      .copy {
         text-align: center;
      }
   }
</style>