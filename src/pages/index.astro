---
import MainLay from '../layouts/MainLay.astro'
import Hero from '../components/landing/1_Hero.astro';
import Pain from '../components/landing/2_Pain.astro';
import Compare from '../components/landing/3_Compare.astro';
import Founder from '../components/landing/4a_Founder.astro';
import Vision from '../components/landing/4b_Vision.astro';
import Action from '../components/landing/4c_Actions.astro';
import Footer from '../components/landing/5_Footer.astro';

import data from '../content/landing.json';
import { SITE_TITLE } from '../content/consts.ts'
---

<MainLay title={SITE_TITLE} description="A new idea for creators to build an online home for their content and community.">
   <Hero data={data.hero} />
   <Pain data={data.pain} />
   <Compare data={data.compare} />
   <Founder data={data.founder} />
   <Vision data={data.vision} />
   <Action data={data.action} />
   <Footer data={data.footer} />
</MainLay>