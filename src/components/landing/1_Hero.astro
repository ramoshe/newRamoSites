---
import Header from '../Header.astro';
import Button from '../Button.astro';
import { YouTube } from 'astro-embed';
import { LINKS } from '../../content/consts.ts';

interface Props {
   data: {
      copy: { heading: string, attention: string, subheading: string, tagline: string },
      video: {url: string, caption: string,},
      cta: {link: string, text: string}
   };
}

const { data } = Astro.props as Props;
---

<Header />

<section class="hero">

   <div class="hero_content | half first-half">
      <h1 class="hero_head">{data.copy.heading}</h1>
      <p class="hero_attn">{data.copy.attention}</p>
      <h2 class="hero_sbhead">{data.copy.subheading}</h2>
      <p class="hero_tag">{data.copy.tagline}</p>
   </div>

   <div class="hero_video | half second-half">
      <p class="video_text">{data.video.caption}</p>
      <div class="video_embed">
         <YouTube id={data.video.url} />
      </div>
   </div>

</section>

<section class="cta" id="first-cta">

   <Button text={data.cta.link} link={LINKS.survey} classList="cta_btn btn btn-large" />
   <p class="cta_text">{data.cta.text}</p>

</section>

<style>
   .hero {
      display: grid;
      align-items: center;
      justify-content: center;
      grid-template-columns: 1fr 1fr;
      inline-size: 100%;
      gap: var(--size-7);
      border: 2px solid lightgray;
      padding: var(--size-7);
   }
   .hero_content {
      display: flex;
      flex-direction: column;
   }
   .cta {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: var(--size-7);
      padding: var(--size-fluid-6);
   }
   .video_embed {
      inline-size: 100%;
      aspect-ratio: 16/9;
   }
</style>