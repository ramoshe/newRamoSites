---
import VisionDiagram from '../assets/visionDiagram.astro';

interface Props {
   data: {
      heading: string,
      body: string[],
      call: string[]
   };
}

const { data } = Astro.props as Props;
---

<section id="vision" class="section">
   <div class="container grid">
      <div class="stack copy">
         <h2>{data.heading}</h2>
         <div class="body flow">{data.body.map(p => <p>{p}</p>)}</div>
         {data.call.map(text => <h3 class="call">{text}</h3>)}
      </div>
      <div class="visual">
         <VisionDiagram />
      </div>
   </div>
</section>

<style>
   .section {
      container-type: inline-size;
   }
   .grid {
      --grid-columns: minmax(22rem, 26rem) 1fr;
      grid-template-areas:"copy visual";
      align-items:center;
   }
   .copy { grid-area:copy; }
   .visual { grid-area:visual; }

   p {
      max-inline-size:100%;
      text-wrap:balance;
   }
   .call {
      text-wrap:unset;
   }

   @container (max-width: 60rem) {
      .stack { text-align: center; }
      .grid {
         --grid-columns: 1fr;
         grid-template-areas:
            "heading"
            "body"
            "visual"
            "call";
      }
      .copy { display: contents; }
      h2 { grid-area: heading; }
      .body { grid-area: body; }
      .visual { grid-area: visual; }
      /* .call { grid-area: call; } */
   }
</style>