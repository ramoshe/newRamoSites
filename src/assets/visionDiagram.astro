---
import { Icon } from "astro-icon/components";

const pieces = [
   {id: "your site", x:50,y:46,  icon: "home",      type: "Home",     size: "hub"},
   {id: "about",     x:39,y:74,  icon: "user",      type: "identity", size: "medium"},
   {id: "artwork",   x:22,y:76,  icon: "palette",   type: "create",   size: "small"},
   {id: "blog",      x:77,y:58,  icon: "article",   type: "create",   size: "big"},
   {id: "booking",   x:43,y:86,  icon: "clock",     type: "connect",  size: "small"},
   {id: "chat",      x:69,y:67,  icon: "messages",  type: "connect",  size: "small"},
   {id: "contact",   x:90,y:54,  icon: "send",      type: "connect",  size: "medium"},
   {id: "courses",   x:10,y:72,  icon: "school",    type: "earn",     size: "small"},
   {id: "donations", x:82,y:44,  icon: "heart",     type: "earn",     size: "big"},
   {id: "downloads", x:68,y:78,  icon: "download",  type: "earn",     size: "small"},
   {id: "email",     x:78,y:30,  icon: "mail",      type: "connect",  size: "big"},
   {id: "events",    x:44,y:10,  icon: "calendar",  type: "connect",  size: "medium"},
   {id: "gallery",   x:20,y:28,  icon: "photo",     type: "create",   size: "big"},
   {id: "livestream",x:9,y:34,   icon: "capture",   type: "connect",  size: "small"},
   {id: "members",   x:28,y:64,  icon: "affiliate", type: "connect",  size: "big"},
   {id: "merch",     x:20,y:44,  icon: "shirt",     type: "earn",     size: "big"},
   {id: "music",     x:5,y:52,   icon: "headphones",type: "create",   size: "small"},
   {id: "podcast",   x:52,y:73,  icon: "microphone",type: "create",   size: "medium"},
   {id: "portfolio", x:56,y:20,  icon: "briefcase", type: "identity", size: "big"},
   {id: "premium",   x:70,y:17,  icon: "lock",      type: "earn",     size: "medium"},
   {id: "press kit", x:63,y:92,  icon: "click",     type: "identity", size: "medium"},
   {id: "profile",   x:17,y:14,  icon: "id",        type: "identity", size: "small"},
   {id: "resume",    x:85,y:72,  icon: "file",      type: "identity", size: "small"},
   {id: "reviews",   x:93,y:34,  icon: "stars",     type: "identity", size: "small"},
   {id: "services",  x:25,y:87,  icon: "briefcase", type: "earn",     size: "medium"},
   {id: "shop",      x:34,y:22,  icon: "basket",    type: "earn",     size: "big"},
   {id: "socials",   x:13,y:59,  icon: "sparkles",  type: "identity", size: "big"},
   {id: "updates",   x:88,y:12,  icon: "bell",      type: "create",   size: "medium"},
   {id: "video",     x:33,y:5,   icon: "video",     type: "create",   size: "medium"},
];
const sizes:any = {
   hub: { radius:0, opacity:1, iconSize:"7rem", labelSize:"1.5rem", },
   big: { radius:.9, opacity:1, iconSize:"3rem", labelSize:"1rem", },
   medium: { radius:.7, opacity:.82, iconSize:"2.5rem", labelSize:".9rem", },
   small: { radius:.5, opacity:.65, iconSize:"2rem", labelSize:".8rem", },
};
const network = { hubOffset:12, pieceOffset:7, dotSpacing:2.5, minDots:3,
   connectionDelay:1.2, dotDelay:.2, };

const pingPong = (count: number) => [...Array.from({length:count},(_,i)=>i),
   ...Array.from({length:count-2},(_,i)=>count-2-i) ];
const styledPieces = pieces.map(piece => ({ ...piece, ...sizes[piece.size], }));
const home:any = styledPieces.find(piece=>piece.size==="hub");

const connections = styledPieces.filter(piece=>piece.size!=="hub")
   .map((piece,c)=>{
      const dx = piece.x-home.x;
      const dy = piece.y-home.y;
      const distance = Math.hypot(dx,dy);
      const startX = (home.x+(dx/distance)*network.hubOffset);
      const startY = (home.y+(dy/distance)*network.hubOffset);
      const endX = (piece.x-(dx/distance)*network.pieceOffset);
      const endY = (piece.y-(dy/distance)*network.pieceOffset);
      const count = Math.max(network.minDots,
         Math.floor(Math.hypot(endX-startX,endY-startY)/network.dotSpacing));
      const path = pingPong(count);
      return {
         color: piece.type, size: piece.size, radius: piece.radius,
         dots: path.map((position,i)=>{
            const progress=position/(count-1);
            return {
               x:startX+(endX-startX)*progress,
               y:startY+(endY-startY)*progress,
               delay:c*network.connectionDelay+i*network.dotDelay,
               direction:i < count-1 ? "out" : "in"
            }; }) }; });
---

<div class="vision-diagram">

   <svg class="network" aria-hidden="true" viewBox={`0 0 100 100`}>
      {connections.map(connection => connection.dots.map(dot => (
      <circle class={`${connection.size} ${dot.direction} ${connection.color}`}
         r={connection.radius} cx={dot.x} cy={dot.y}
         style={`--delay:${dot.delay}s`} /> )) )}
   </svg>

   {styledPieces.map(piece=>(
   <div class={`piece ${piece.type} ${piece.size}`}
      style={`--x:${piece.x}; --y:${piece.y}; --opacity:${piece.opacity};
         --icon-size:${piece.iconSize}; --label-size:${piece.labelSize};`}
   >
      {piece.size === "hub" && <div class="signal-glow"></div> }
      <Icon name={`tabler:${piece.icon}-filled`} />
      <span>{piece.id}</span>
   </div> ))}

</div>

<style>
   .vision-diagram {
      position: relative;
      width: 100%;
      aspect-ratio: 1;
      --scale: 1;
   }

   .piece {
      position: absolute;
      left: calc(var(--x) * 1%);
      top: calc(var(--y) * 1%);
      translate: -50% -50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .35rem;
      z-index: 1;
      color: inherit;
      opacity: var(--opacity);
   }
   .piece svg {
      width: calc(var(--icon-size) * var(--scale));
      height: calc(var(--icon-size) * var(--scale));
   }
   .piece span {
      font-size: calc(var(--label-size) * var(--scale));
      white-space: nowrap;
      line-height: 1;
      text-transform: capitalize;
   }

   .create { color: var(--violet-6); }
   .connect { color: var(--pink-6); }
   .earn { color: var(--green-6); }
   .identity { color: var(--orange-6); }

   .hub {
      flex-direction: column;
      gap: .35rem;
      color: var(--brand-t);
      z-index: 2 !important;
   }
   .signal-glow {
      --signal:var(--brand-pp);
      inset:-140%;
      z-index:-3;
   }

   .network {
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
   }

   @media (max-width: 600px) {
      .vision-diagram { --scale:.7; }
      .piece { gap:.2rem; }
      .signal-glow { inset: -100%; }
   }
</style>
